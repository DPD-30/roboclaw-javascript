{
  "name": "roboclaw-javascript",
  "version": "1.0.0",
  "type": "module",
  "description": "Node.js driver for RoboClaw motor controllers.",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "mocha $(find tests -name '*.test.js' ! -name '*.hw.test.js' ! -name '*hw.test.js')",
    "test:hw": "mocha tests/**/*.hw.test.js",
    "prepublishOnly": "npm run test:unit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DPD-30/roboclaw-javascript.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DPD-30/roboclaw-javascript/issues"
  },
  "homepage": "https://github.com/DPD-30/roboclaw-javascript#readme",
  "dependencies": {
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "eslint": "^8.57.0",
    "mocha": "^11.3.0"
  }
}
